{
  "name": "wb-chronicler",
  "version": "0.0.0",
  "description": "Tolkien-style chronicle for WorldBox playthroughs — Claude Code turns saves into narrative chapters, rendered in a parchment-themed Angular reader.",
  "keywords": [
    "angular",
    "claude-code",
    "narrative",
    "ngx-markdown",
    "tolkien",
    "worldbox"
  ],
  "author": {
    "name": "Jean-benoit Gautier"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jbz797/wb-chronicler.git"
  },
  "bugs": {
    "url": "https://github.com/Jbz797/wb-chronicler/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ng build",
    "lint": "ng lint && stylelint \"src/**/*.scss\" && prettier --check \"src/**/*.html\"",
    "lint:fix": "ng lint --fix && stylelint --fix \"src/**/*.scss\" && prettier --write \"src/**/*.html\"",
    "start": "concurrently --kill-others --names \"ng,watch\" -c \"green,cyan\" \"ng serve\" \"node scripts/watch-saves.mjs\""
  },
  "dependencies": {
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@angular/router": "22.0.7",
    "marked": "18.0.6",
    "marked-gfm-heading-id": "4.1.4",
    "ng-zorro-antd": "21.3.2",
    "ngx-markdown": "22.0.0",
    "prism-themes": "1.9.0",
    "prismjs": "1.30.0",
    "rxjs": "7.8.2",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@angular/language-service": "22.0.7",
    "chokidar": "5.0.0",
    "concurrently": "10.0.3",
    "eslint-config-angular-strict": "22.1.2",
    "less": "4.6.7",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-prettier": "5.0.3",
    "typescript": "6.0.3"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
}
