{
  "name": "wb-chronicler",
  "version": "0.0.0",
  "description": "Tolkien-style chronicle for WorldBox playthroughs — Claude Code turns saves into narrative chapters, rendered in a parchment-themed Angular reader.",
  "keywords": [
    "angular",
    "claude-code",
    "narrative",
    "ngx-markdown",
    "tolkien",
    "worldbox"
  ],
  "author": {
    "name": "Jean-benoit Gautier"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jbz797/wb-chronicler.git"
  },
  "bugs": {
    "url": "https://github.com/Jbz797/wb-chronicler/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ng build",
    "lint": "ng lint && stylelint \"src/**/*.scss\" && prettier --check \"src/**/*.html\"",
    "lint:fix": "ng lint --fix && stylelint --fix \"src/**/*.scss\" && prettier --write \"src/**/*.html\"",
    "start": "concurrently --kill-others --names \"ng,watch\" -c \"green,cyan\" \"ng serve\" \"node scripts/watch-saves.mjs\""
  },
  "dependencies": {
    "@angular/common": "21.2.12",
    "@angular/compiler": "21.2.12",
    "@angular/core": "21.2.12",
    "@angular/platform-browser": "21.2.12",
    "@angular/router": "^21.2.12",
    "marked": "^18.0.3",
    "marked-gfm-heading-id": "^4.1.4",
    "ng-zorro-antd": "^21.2.2",
    "ngx-markdown": "^21.3.0",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/language-service": "^21.2.12",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint-config-angular-strict": "^2.3.87",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.9.3"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
