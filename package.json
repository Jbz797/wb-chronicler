{
  "name": "wb-chronicler",
  "version": "0.0.0",
  "description": "Tolkien-style chronicle for WorldBox playthroughs — Claude Code turns saves into narrative chapters, rendered in a parchment-themed Angular reader.",
  "keywords": [
    "angular",
    "claude-code",
    "narrative",
    "ngx-markdown",
    "tolkien",
    "worldbox"
  ],
  "author": {
    "name": "Jean-benoit Gautier"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jbz797/wb-chronicler.git"
  },
  "bugs": {
    "url": "https://github.com/Jbz797/wb-chronicler/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ng build",
    "lint": "ng lint && stylelint \"src/**/*.scss\" && prettier --check \"src/**/*.html\"",
    "lint:fix": "ng lint --fix && stylelint --fix \"src/**/*.scss\" && prettier --write \"src/**/*.html\"",
    "start": "concurrently --kill-others --names \"ng,watch\" -c \"green,cyan\" \"ng serve\" \"node scripts/watch-saves.mjs\""
  },
  "dependencies": {
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/router": "^21.2.14",
    "marked": "^18.0.4",
    "marked-gfm-heading-id": "^4.1.4",
    "ng-zorro-antd": "^21.3.0",
    "ngx-markdown": "^21.3.0",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@angular/language-service": "^21.2.14",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint-config-angular-strict": "^2.3.92",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.9.3"
  },
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53"
}
